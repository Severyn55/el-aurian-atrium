---
// src/components/MobileMenu.astro
import { navigationItems } from '../data/navigation';
import { getEntry } from 'astro:content';

interface Props {
  id?: string;
}

const { id = 'mobile-menu' } = Astro.props;

const labels = await getEntry('labels', 'main');

const navLabels: Record<string, string | undefined> = {
  Karte: labels?.data?.nav_karte,
  Konzept: labels?.data?.nav_konzept,
  Begegnungen: labels?.data?.nav_begegnungen,
  Events: labels?.data?.nav_events,
  Member: labels?.data?.nav_member,
  Reservierung: labels?.data?.nav_reservierung,
};
---

<div 
  id={id}
  class="hidden fixed inset-0 z-[999] xl:hidden flex-col menu-overlay"
  aria-hidden="true"
>
  <!-- Elegant semi-transparent dark background with light blur -->
  <div class="absolute inset-0 bg-[#0A0907]/95 backdrop-blur-[2px]"></div>

  <!-- Refined architectural top gold accent line -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#C5A46E]/25 to-transparent z-10"></div>

  <!-- Content wrapper - sits above the solid dark background -->
  <div class="relative z-[10] flex flex-col h-full">

  <!-- Top bar -->
  <div class="flex items-center justify-between px-8 pt-8 pb-2 border-b border-[#C5A46E]/10">
    <div class="label-tight tracking-[3.5px] text-white">{labels?.data?.menu_label ?? 'MENÜ'}</div>
    <button 
      id="mobile-menu-close"
      class="text-[42px] leading-none text-white/80 hover:text-[#C5A46E] transition-colors -mr-3 -mt-4"
      aria-label="Menü schließen"
    >
      ×
    </button>
  </div>

  <!-- Navigation Links -->
  <div class="flex-1 px-8 pt-10 relative z-10">
    <nav class="flex flex-col gap-y-[22px]">
      {
        navigationItems.map((item) => (
          <a 
            href={item.href} 
            class="mobile-menu-link group relative text-[28px] leading-none tracking-[-0.4px] text-white hover:text-[#C5A46E] transition-colors flex items-center"
          >
            {navLabels[item.label] || item.label}
          </a>
        ))
      }
    </nav>
  </div>

  <!-- Primary CTA -->
  <div class="px-8 py-9 border-t border-[#C5A46E]/25 relative z-10 bg-gradient-to-b from-transparent via-[#0A0907]/40 to-[#0A0907]/70">
    <button 
      onclick="window.openReservationModal && window.openReservationModal()"
      class="btn btn-primary w-full py-[17px] text-[13px] tracking-[2.5px] border border-[#C5A46E]/30 hover:border-[#C5A46E]/60"
    >
      {labels?.data?.cta_tisch_reservieren ?? 'TISCH RESERVIEREN'}
    </button>
  </div>

  </div> <!-- end of content wrapper -->
</div> <!-- end of menu-overlay -->

<style>
  /* ============================================
     PREMIUM MOBILE MENU - ELEGANT HALF-TRANSPARENT BACKGROUND
     Creative direction: Deep warm near-black with architectural 
     gold micro-glow + refined vertical depth. Gold design remains 
     the clear hero. No photo assets. Full coverage, high readability.
     ============================================ */

  .menu-overlay {
    transition: opacity var(--duration-slow) var(--ease-decelerate);
    opacity: 0;
  }

  .menu-overlay.menu-open {
    opacity: 1;
  }

  .menu-overlay.menu-entering {
    opacity: 0;
  }

  .menu-overlay.menu-exiting {
    opacity: 0;
    transition: opacity 260ms var(--ease-exit);
  }

  /* Content container animation */
  .menu-overlay > div {
    transition: transform var(--duration-slow) var(--ease-emphasized),
                opacity var(--duration-slow) var(--ease-decelerate);
    transform: translateY(20px);
    opacity: 0;
  }

  .menu-overlay.menu-open > div {
    transform: translateY(0);
    opacity: 1;
  }

  .menu-overlay.menu-exiting > div {
    transform: translateY(12px);
    opacity: 0;
    transition: transform 260ms var(--ease-exit),
                opacity 260ms var(--ease-exit);
  }

  /* Staggered navigation links */
  .menu-overlay .mobile-menu-link {
    opacity: 0;
    transform: translateY(16px);
    transition: 
      opacity 380ms var(--ease-emphasized),
      transform 380ms var(--ease-emphasized);
  }

  .menu-overlay.menu-open .mobile-menu-link {
    opacity: 1;
    transform: translateY(0);
  }

  /* Stagger delays */
  .menu-overlay.menu-open .mobile-menu-link:nth-child(1) { transition-delay: 80ms; }
  .menu-overlay.menu-open .mobile-menu-link:nth-child(2) { transition-delay: 130ms; }
  .menu-overlay.menu-open .mobile-menu-link:nth-child(3) { transition-delay: 180ms; }
  .menu-overlay.menu-open .mobile-menu-link:nth-child(4) { transition-delay: 230ms; }
  .menu-overlay.menu-open .mobile-menu-link:nth-child(5) { transition-delay: 280ms; }
  .menu-overlay.menu-open .mobile-menu-link:nth-child(6) { transition-delay: 330ms; }

  .menu-overlay.menu-exiting .mobile-menu-link {
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 220ms var(--ease-exit), transform 220ms var(--ease-exit);
  }

  /* Gold Whisper Hover Effects for premium feel */
  .mobile-menu-link::before {
    content: '';
    position: absolute;
    left: -18px;
    top: 50%;
    transform: translateY(-50%);
    width: 5px;
    height: 5px;
    background-color: #C5A46E;
    border-radius: 50%;
    opacity: 0;
    transition: all 280ms var(--ease-emphasized);
  }

  .mobile-menu-link:hover::before {
    opacity: 1;
    left: -22px;
  }

  .mobile-menu-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    height: 1px;
    width: 0;
    background: linear-gradient(to right, #C5A46E, #D4B47A);
    transition: width 380ms var(--ease-emphasized);
  }

  .mobile-menu-link:hover::after {
    width: 100%;
  }

  /* Reduced motion support */
  @media (prefers-reduced-motion: reduce) {
    .menu-overlay,
    .menu-overlay > div,
    .menu-overlay .mobile-menu-link {
      transition: none !important;
      transform: none !important;
      opacity: 1 !important;
    }
  }

</style>
