---
import Image from './ui/Image.astro';

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;

// Image imports (move originals to src/assets/images/interior/)
import barImage from '../assets/images/interior/20260604-kuechenbereich.jpg';
import tablesImage from '../assets/images/interior/20260604-speisesaal.jpg';
import windowImage from '../assets/images/interior/20260604-innenraum-eingang.jpg';
import terraceImage from '../assets/images/interior/20260604-dining-area.jpg';
import menuWallImage from '../assets/images/interior/20260604-speisekarte-wand.jpg';

// Editable copy from collections (Konzept section)
import { getEntry } from 'astro:content';
const konzeptEntry = await getEntry('konzept', 'konzept');
const { Content } = await konzeptEntry.render();
const labels = await getEntry('labels', 'main');
---

<section id="konzept" class={`max-w-screen-2xl mx-auto px-8 py-20 ${className}`}>
  <div class="mb-10">
    <div class="label text-[#C5A46E] mb-3">{labels?.data?.label_konzept ?? 'DAS KONZEPT'}</div>
    <h2 class="serif text-heading mb-4">{konzeptEntry?.data?.headline ?? 'Modernste Web-Architektur.'}</h2>

    <!-- Side-by-side text + image on desktop (1080p+), stack on mobile for craft -->
    <div class="lg:grid lg:grid-cols-12 lg:gap-x-8 lg:items-start">
      <div class="lg:col-span-7">
        <div class="gold-frame p-6 md:p-8 bg-[#1A1714] mb-4 md:mb-0">
          <div class="prose prose-invert text-[#A89F90]">
            <Content />
          </div>
        </div>
      </div>
      <div class="hidden lg:block lg:col-span-5 mt-6 lg:mt-2">
        <Image 
          src={windowImage} 
          alt="Eingangsbereich mit Blick in den Innenraum" 
          widths={[600, 800, 1000]}
          sizes="(max-width: 1024px) 100vw, 40vw"
          goldFrame={true}
          subtleLift={true}
          class="w-full aspect-[16/10] object-cover"
        />
        <div class="text-[10px] tracking-[1.5px] text-[#C5A46E]/60 mt-1.5 text-right">KONZEPT &amp; RAUM</div>
      </div>
    </div>
  </div>

  <!-- Interieur Grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
    
    <div class="group aspect-[4/3] relative">
      <Image 
        src={barImage} 
        alt="Bar-Bereich mit offener Küche und Kupfergeschirr" 
        width={1000}
        height={750}
        widths={[400, 700, 1000]}
        sizes="(max-width: 768px) 100vw, 25vw"
        goldFrame={true}
        subtleLift={true}
      />
      <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/70 to-transparent p-6">
        <div class="label-tight text-white">DER BAR-BEREICH</div>
      </div>
    </div>

    <div class="group aspect-[4/3] relative">
      <Image 
        src={tablesImage} 
        alt="Speisesaal mit Holztischen und Wandbildern" 
        widths={[400, 700, 1000]}
        sizes="(max-width: 768px) 100vw, 25vw"
        goldFrame={true}
        subtleLift={true}
      />
      <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/70 to-transparent p-6">
        <div class="label-tight text-white">HOHE TISCHE & LANGE ABENDE</div>
      </div>
    </div>

    <div class="group aspect-[4/3] relative">
      <Image 
        src={menuWallImage} 
        alt="Wand mit Portfolio Tasting Menu und gerahmten Bildern" 
        widths={[400, 700, 1000]}
        sizes="(max-width: 768px) 100vw, 25vw"
        goldFrame={true}
        subtleLift={true}
      />
      <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/70 to-transparent p-6">
        <div class="label-tight text-white">TAGESLICHT & STADTNÄHE</div>
      </div>
    </div>

    <div class="group aspect-[4/3] relative">
      <Image 
        src={terraceImage} 
        alt="Dining-Bereich mit gedeckten Tischen und Wandbildern" 
        widths={[400, 700, 1000]}
        sizes="(max-width: 768px) 100vw, 25vw"
        goldFrame={true}
        subtleLift={true}
      />
      <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/70 to-transparent p-6">
        <div class="label-tight text-white">SPEISESAAL</div>
      </div>
    </div>

  </div>

  <!-- Stats -->
  <div class="mt-8 flex justify-center">
    <div class="inline-flex items-center gap-x-8 text-sm text-[#A89F90]">
      <div><span class="font-medium text-white">30</span> seated</div>
      <div class="w-px h-3 bg-white/30"></div>
      <div><span class="font-medium text-white">50</span> standing</div>
      <div class="w-px h-3 bg-white/30"></div>
      <div>The Nexus Promenade, Starbase 47</div>
    </div>
  </div>
</section>