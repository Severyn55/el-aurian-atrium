---
/**
 * Hero & Einstieg Editor Card
 */
---

<div class="admin-card mb-8">
  <div class="admin-card-header">
    <div>
      <div class="admin-card-title">Hero &amp; Einstieg</div>
      <div class="admin-card-subtitle tracking-[-0.4px]">Haupt-Headline &amp; Call-to-Action</div>
    </div>
    <button onclick="loadHeroArea()" class="admin-btn admin-btn-ghost text-xs">Daten laden</button>
  </div>

  <div class="admin-card-body">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="admin-label">Headline (großes H1)</label>
        <input id="hero-headline" class="admin-input" placeholder="The El-Aurian Atrium" />
      </div>
      <div>
        <label class="admin-label">Button Text</label>
        <input id="hero-cta" class="admin-input" placeholder="TISCH RESERVIEREN" />
      </div>
    </div>

    <div class="mt-4">
      <button onclick="saveHeroArea()" class="admin-btn admin-btn-primary text-xs">Hero speichern</button>
      <span id="hero-status" class="admin-status ml-3"></span>
    </div>
  </div>
</div>
