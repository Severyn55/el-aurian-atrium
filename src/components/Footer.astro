---
import { getEntry } from 'astro:content';
const labels = await getEntry('labels', 'main');
const igUrl = labels?.data?.instagram_url ?? 'https://www.instagram.com/chromaticchris44/';
---

<footer class="max-w-screen-2xl mx-auto px-8 py-12 text-xs text-[#A89F90] flex flex-col md:flex-row justify-between gap-y-3 border-t border-white/10">
  <div class="flex items-center gap-x-2">
    <span>© The El-Aurian Atrium by Ambassador Veylan. All rights reserved.</span>
    <span class="text-[#C5A46E]/60 font-mono text-ui-sm">v0.4.0</span>
    <a href={`${import.meta.env.BASE_URL || '/'}admin/speisekarten`} class="text-[#C5A46E]/40 hover:text-[#C5A46E] text-[10px] font-mono ml-2" title="Nur für Betreiber: Speisekarten-Editor mit GitHub-Token">Admin</a>
  </div>

  <div class="flex flex-wrap items-center gap-x-6 gap-y-2">
    <a 
      href={igUrl} 
      target="_blank" 
      class="inline-flex items-center gap-x-2 hover:text-[#C5A46E] transition-colors py-2"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="3" width="18" height="18" rx="5" ry="5"></rect>
        <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
        <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
      </svg>
      <span>Instagram</span>
    </a>

    <a href={`${import.meta.env.BASE_URL || '/'}impressum`} class="hover:text-[#C5A46E] transition-colors py-2">Impressum</a>
    <a href={`${import.meta.env.BASE_URL || '/'}datenschutz`} class="hover:text-[#C5A46E] transition-colors py-2">Datenschutz</a>
  </div>
</footer>